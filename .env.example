ANTHROPIC_MODEL=deepseek-v4-flash
ANTHROPIC_TEST_PROMPT=Confirm the environment is configured correctly in one short sentence.

LANGSMITH_API_KEY=replace-with-your-langsmith-key
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=summer-anthropic-lab

